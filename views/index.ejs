<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Rain Forecast — <%= city %></title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <div class="noise"></div>

  <div class="page">

    <!-- ── Header + Search ── -->
    <header>
      <div class="header-top">
        <div>
          <div class="location-tag">🌦 Rain Forecast</div>
          <h1>Tomorrow's<br/><em>Forecast</em></h1>
        </div>
        <button class="refresh-btn" onclick="refreshWeather()" title="Refresh">
          <svg id="refresh-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
        </button>
      </div>

      <!-- Search Form -->
      <form action="/search" method="POST" class="search-form">
        <input type="text" name="city" placeholder="Search any city..." value="<%= city %>" autocomplete="off" />
        <button type="submit">Search</button>
      </form>

      <!-- Recent Searches -->
      <% if (recentSearches && recentSearches.length > 0) { %>
      <div class="recent-searches">
        <span class="recent-label">Recent:</span>
        <% recentSearches.forEach(function(c) { %>
          <a href="/?city=<%= encodeURIComponent(c) %>" class="recent-chip"><%= c %></a>
        <% }) %>
      </div>
      <% } %>
    </header>

    <!-- ── Error ── -->
    <% if (error) { %>
    <div class="error-card">
      <p><%= error %></p>
    </div>
    <% } %>

    <!-- ── Main Forecast Card ── -->
    <% if (rainData) { %>
    <main class="card <%= rainData.willRain ? 'is-rain' : 'is-clear' %>">
      <div class="verdict-row">
        <div class="verdict-icon">
          <img src="https://openweathermap.org/img/wn/<%= rainData.icon %>@2x.png" alt="weather icon"/>
        </div>
        <div class="verdict-text">
          <span class="verdict-label">📍 <%= rainData.city %>, <%= rainData.country %></span>
          <h2><%= rainData.willRain ? 'Bring your umbrella.' : 'Leave it at home.' %></h2>
          <p class="condition-desc"><%= rainData.description %></p>
        </div>
      </div>

      <div class="divider"></div>

      <div class="stats">
        <div class="stat">
          <span class="stat-value"><%= rainData.pop %><sup>%</sup></span>
          <span class="stat-label">Rain chance</span>
        </div>
        <div class="stat">
          <span class="stat-value"><%= rainData.tempMin %>°<span class="sep">–</span><%= rainData.tempMax %>°</span>
          <span class="stat-label">Temp range (°C)</span>
        </div>
        <div class="stat">
          <span class="stat-value"><%= rainData.feelsLike %>°</span>
          <span class="stat-label">Feels like</span>
        </div>
        <div class="stat">
          <span class="stat-value"><%= rainData.humidity %><sup>%</sup></span>
          <span class="stat-label">Humidity</span>
        </div>
        <div class="stat">
          <span class="stat-value"><%= rainData.windSpeed %><sup>m/s</sup></span>
          <span class="stat-label">Wind speed</span>
        </div>
        <% if (rainData.rain > 0) { %>
        <div class="stat">
          <span class="stat-value"><%= rainData.rain %><sup>mm</sup></span>
          <span class="stat-label">Rainfall</span>
        </div>
        <% } %>
      </div>

      <div class="date-bar">
        <span><%= rainData.date %></span>
        <span class="dot">·</span>
        <span>As of <%= rainData.time %></span>
      </div>
    </main>

    <!-- ── Hourly Chart ── -->
    <% if (hourlyChart && hourlyChart.length > 0) { %>
    <section class="section-card">
      <h3 class="section-title">Next 24 Hours</h3>
      <div class="chart-container">
        <canvas id="hourlyChart"></canvas>
      </div>
    </section>
    <% } %>

    <!-- ── 5-Day Forecast ── -->
    <% if (fiveDay && fiveDay.length > 0) { %>
    <section class="section-card">
      <h3 class="section-title">5-Day Outlook</h3>
      <div class="five-day">
        <% fiveDay.forEach(function(day) { %>
        <div class="day-card">
          <span class="day-name"><%= day.day %></span>
          <span class="day-date"><%= day.date %></span>
          <img src="https://openweathermap.org/img/wn/<%= day.icon %>@2x.png" alt="<%= day.description %>"/>
          <span class="day-desc"><%= day.description %></span>
          <span class="day-temps"><%= day.tempMin %>° – <%= day.tempMax %>°</span>
          <span class="day-pop <%= day.pop >= 40 ? 'wet' : '' %>">💧 <%= day.pop %>%</span>
        </div>
        <% }) %>
      </div>
    </section>
    <% } %>

    <% } %>

    <footer>
      <span>Powered by OpenWeatherMap · Built with Express &amp; Axios</span>
    </footer>
  </div>

  <!-- Chart.js -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>

  <script>
  // ── Hourly Chart ──
  <% if (hourlyChart && hourlyChart.length > 0) { %>
    
    const labels = <%- JSON.stringify(hourlyChart.map(h => h.time)) %>;
    const temps  = <%- JSON.stringify(hourlyChart.map(h => Number(h.temp))) %>;
    const pops   = <%- JSON.stringify(hourlyChart.map(h => Number(h.pop))) %>;

    const canvas = document.getElementById('hourlyChart');

    if (canvas) {
      const ctx = canvas.getContext('2d');

      new Chart(ctx, {
        type: 'line',
        data: {
          labels: labels,
          datasets: [
            {
              label: 'Temperature (°C)',
              data: temps,
              borderColor: '#e8a830',
              backgroundColor: 'rgba(232,168,48,0.08)',
              tension: 0.4,
              fill: true,
              pointBackgroundColor: '#e8a830',
              pointRadius: 4,
              yAxisID: 'yTemp'
            },
            {
              label: 'Rain chance (%)',
              data: pops,
              borderColor: '#4a90d9',
              backgroundColor: 'rgba(74,144,217,0.08)',
              tension: 0.4,
              fill: true,
              pointBackgroundColor: '#4a90d9',
              pointRadius: 4,
              yAxisID: 'yPop'
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          plugins: {
            legend: {
              labels: {
                color: '#9a9db0',
                font: { family: 'DM Sans', size: 12 },
                boxWidth: 12
              }
            }
          },
          scales: {
            x: {
              ticks: {
                color: '#7a7d8a',
                font: { family: 'DM Sans', size: 11 }
              },
              grid: { color: 'rgba(255,255,255,0.05)' }
            },
            yTemp: {
              position: 'left',
              ticks: {
                color: '#e8a830',
                font: { family: 'DM Sans', size: 11 },
                callback: (v) => v + '°'
              },
              grid: { color: 'rgba(255,255,255,0.05)' }
            },
            yPop: {
              position: 'right',
              min: 0,
              max: 100,
              ticks: {
                color: '#4a90d9',
                font: { family: 'DM Sans', size: 11 },
                callback: (v) => v + '%'
              },
              grid: { drawOnChartArea: false }
            }
          }
        }
      });
    }

  <% } %>

  // ── Refresh button ──
  function refreshWeather() {
    const icon = document.getElementById('refresh-icon');
    if (!icon) return;

    icon.style.transition = 'transform 0.6s ease';
    icon.style.transform = 'rotate(360deg)';

    setTimeout(() => { icon.style.transform = ''; }, 700);
    setTimeout(() => window.location.reload(), 300);
  }
</script>

</body>
</html>
